{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
		{
			"name": "DEBUG (Windows)",
			"type": "cppvsdbg",
			"request": "launch",
            "program": "${workspaceFolder}/build/Debug/palomar.exe",
			"cwd": "${workspaceFolder}",
			"args": ["scenes/cube.json"],
			"stopAtEntry": false,
			"console": "externalTerminal",
            "environment": [
                {"name": "VK_LAYER_PATH", "value": "${workspaceFolder}/lib/windows"}
            ]
		},
        {
            "name": "DEBUG (MacOS)",
            "request": "launch",
            "type": "cppdbg",
            "program": "${workspaceFolder}/build/palomar",
            "cwd": "${workspaceFolder}",
            "args": ["scenes/cube.json"],
            "targetArchitecture": "arm64",
            "MIMode": "lldb",
            "environment": [
                {"name": "VK_LAYER_PATH", "value": "${workspaceFolder}/lib/macos"},
                {"name": "DYLD_LIBRARY_PATH", "value": "${workspaceFolder}/lib/macos"}
            ]
        }
    ]
}